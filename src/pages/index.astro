---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import site from "../data/site.json";

const { nav, brand, hero, trust, conferences, quote, parcours, tiles, brands, contact, footer } = site;
---

<Base>
  <a id="top"></a>
  <Header />

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="container hero__inner">
        <div class="hero__text reveal">
          <h1 class="hero__title">
            <span>{hero.titleLine1}</span>
            <span>{hero.titleLine2}</span>
          </h1>
          <p class="hero__subtitle">{hero.subtitle}</p>
          <a class="btn btn--light" href={hero.cta.href}>{hero.cta.label}</a>
        </div>
        <div class="hero__media reveal">
          <div class="hero__photo">
            <img src={hero.image} alt={hero.imageAlt} loading="eager" width="640" height="760" />
          </div>
        </div>
      </div>
    </section>

    <!-- TRUST -->
    <section class="trust section">
      <div class="container">
        <h2 class="trust__title reveal">{trust.title}</h2>
      </div>
      <div class="marquee">
        <div class="marquee__track">
          {trust.logos.map((l) => <img src={l.image} alt={l.name} class="trust__logo" />)}
          {trust.logos.map((l) => <img src={l.image} alt="" aria-hidden="true" class="trust__logo" />)}
        </div>
      </div>
    </section>

    <!-- CONFERENCES -->
    <section class="section conf" id={conferences.id}>
      <div class="container conf__inner">
        <div class="conf__text reveal">
          <h2 class="h2">{conferences.title}</h2>
          <p class="lead">{conferences.text}</p>
          <a class="btn btn--ghost" href={conferences.cta.href}>{conferences.cta.label}</a>
        </div>
        <div class="conf__media reveal">
          {conferences.images.map((im) => (
            <div class="conf__card"><img src={im.image} alt={im.alt} /></div>
          ))}
        </div>
      </div>
    </section>

    <!-- QUOTE -->
    <section class="section quote">
      <div class="container">
        <blockquote class="quote__text reveal">
          <span class="quote__mark">“</span>{quote.text}<span class="quote__mark">”</span>
        </blockquote>
        <p class="quote__author reveal">
          <strong>{quote.author}</strong> · {quote.source}
        </p>
      </div>
    </section>

    <!-- PARCOURS -->
    <section class="section parcours" id={parcours.id}>
      <div class="container">
        <p class="eyebrow reveal">{parcours.eyebrow}</p>
        <h2 class="h2 reveal">{parcours.title}</h2>
        <div class="parcours__body reveal">
          {parcours.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <!-- TILES -->
    <section class="tiles">
      <div class="container tiles__grid">
        {tiles.map((t) => (
          <div class="tile reveal"><img src={t.image} alt={t.alt} loading="lazy" /></div>
        ))}
      </div>
    </section>

    <!-- BRANDS -->
    {brands.map((b) => (
      <section class="section brand" id={b.id} style={`--accent:${b.accent}`}>
        <div class={`container brand__inner ${b.layout === "image-right" ? "brand__inner--reverse" : ""}`}>
          <div class="brand__media reveal">
            <div class="brand__photo"><img src={b.image} alt={b.imageAlt} /></div>
          </div>
          <div class="brand__text reveal">
            <h2 class="h2">{b.name}</h2>
            {b.paragraphs.map((p) => <p class="lead">{p}</p>)}
            {(b.avatars?.length || b.stat) && (
              <div class="brand__proof">
                {b.avatars && b.avatars.length > 0 && (
                  <div class="brand__avatars">
                    {b.avatars.map((a) => <img class="brand__avatar" src={a} alt="" loading="lazy" width="52" height="52" />)}
                  </div>
                )}
                {b.stat && <p class="brand__stat">{b.stat}</p>}
              </div>
            )}
            <div class="brand__actions">
              {b.linktree && (
                <a class="btn brand__follow" href={b.linktree} target="_blank" rel="noopener noreferrer">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v18"/><path d="M5 8l7-4 7 4"/><path d="M5 14l7 4 7-4"/></svg>
                  Nous suivre
                </a>
              )}
              <a
                class="btn"
                style={`background:var(--accent);color:${b.ctaText || "#fff"}`}
                href={b.cta.href}
                target={b.cta.href.startsWith("http") ? "_blank" : undefined}
                rel={b.cta.href.startsWith("http") ? "noopener noreferrer" : undefined}
              >{b.cta.label}</a>
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- CONTACT -->
    <section class="section contact" id={contact.id}>
      <div class="container contact__inner">
        <div class="contact__intro reveal">
          <h2 class="h2">{contact.title}</h2>
          <p class="lead">{contact.text}</p>
        </div>

        <form
          class="form reveal"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/merci"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="visually-hidden">
            <label>Ne pas remplir : <input name="bot-field" /></label>
          </p>
          <div class="form__row">
            <label class="field">
              <span>Nom</span>
              <input type="text" name="nom" required autocomplete="name" />
            </label>
            <label class="field">
              <span>Email</span>
              <input type="email" name="email" required autocomplete="email" />
            </label>
          </div>
          <label class="field">
            <span>Sujet</span>
            <input type="text" name="sujet" />
          </label>
          <label class="field">
            <span>Message</span>
            <textarea name="message" rows="5" required></textarea>
          </label>
          <button class="btn btn--light" type="submit">Envoyer le message</button>
        </form>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__grid">
      <div class="footer__brand">
        <a class="footer__logo" href="#top" aria-label={brand.name}>
          <img src={brand.logo} alt={brand.name} />
        </a>
        <p class="footer__bio">{footer.bio}</p>
      </div>

      <div class="footer__explore">
        <p class="footer__heading">Explorer</p>
        <nav class="footer__links" aria-label="Liens du site">
          {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>

      <div class="footer__connect">
        <p class="footer__phrase">{footer.tagline}</p>
        <p class="footer__heading">Suivez-moi</p>
        <div class="footer__socials">
          <a class="footer__social" href={footer.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">in</a>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="container footer__legal">
        <a href="/mentions-legales">Mentions légales</a>
        <span aria-hidden="true">·</span>
        <span>© 2026 {brand.name}</span>
        <span aria-hidden="true">·</span>
        <span>Tous droits réservés</span>
      </p>
    </div>
  </footer>
</Base>

<style>
  .h2 { font-size: clamp(2rem, 5vw, 3.2rem); margin-bottom: 18px; }
  .lead { color: var(--muted); font-size: 1.08rem; max-width: 46ch; margin: 0 0 26px; }

  /* HERO */
  .hero { padding-top: clamp(36px, 6vw, 80px); padding-bottom: clamp(24px, 4vw, 48px); }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 5vw, 64px);
    align-items: center;
  }
  .hero__title {
    font-size: clamp(2.4rem, 6vw, 4.6rem);
    font-weight: 900;
    display: flex;
    flex-direction: column;
  }
  .hero__subtitle {
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    color: var(--muted);
    margin: 24px 0 32px;
    max-width: 28ch;
  }
  .hero__photo { display: flex; justify-content: center; }
  .hero__photo img { width: 100%; height: auto; display: block; }

  /* TRUST */
  .trust { padding-block: clamp(32px, 5vw, 64px); }
  .trust__title { text-align: center; color: #fff; margin: 0 0 40px; font-family: var(--font-head); font-weight: 800; font-size: clamp(1.6rem, 4vw, 2.4rem); letter-spacing: -0.01em; }
  .marquee {
    overflow: hidden; width: 100%;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .marquee__track { display: flex; align-items: center; width: max-content; animation: marquee-slide 30s linear infinite; }
  .marquee:hover .marquee__track { animation-play-state: paused; }
  .trust__logo { height: 40px; width: auto; margin-right: clamp(48px, 7vw, 96px); filter: brightness(0) invert(1); opacity: 0.8; flex: none; }
  @keyframes marquee-slide { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .marquee__track { animation: none; } }

  /* CONFERENCES */
  .conf__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 5vw, 64px);
    align-items: center;
  }
  .conf__media { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .conf__card {
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: linear-gradient(160deg, var(--navy-2), #060615);
  }
  .conf__card img { width: 100%; height: 100%; object-fit: cover; }

  /* QUOTE */
  .quote { text-align: left; padding-block: clamp(24px, 4vw, 56px); }
  .quote__text {
    font-family: var(--font-head);
    font-weight: 800;
    font-style: italic;
    font-size: clamp(1.6rem, 4.4vw, 3rem);
    line-height: 1.15;
    margin: 0 0 20px;
    max-width: none;
  }
  .quote__mark { color: var(--accent); }
  .quote__author { color: var(--muted-2); margin: 0; }
  .quote__author strong { color: var(--text); }

  /* PARCOURS */
  .parcours__body { margin-top: 12px; }
  .parcours__body p { margin: 0 0 20px; color: var(--muted); }

  /* TILES */
  .tiles { padding-block: clamp(8px, 2vw, 24px); }
  .tiles__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(14px, 2vw, 22px); }
  .tile {
    aspect-ratio: 3 / 4;
    border-radius: var(--radius);
    overflow: hidden;
  }
  .tile img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* BRANDS */
  .brand__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 5vw, 64px);
    align-items: center;
  }
  .brand__inner--reverse .brand__media { order: 2; }
  .brand__photo {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: linear-gradient(160deg, var(--navy-2), #060615);
  }
  .brand__photo img { width: 100%; height: 100%; object-fit: cover; }
  .brand__actions { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  .brand__follow {
    background: transparent;
    border-color: var(--line);
    color: #fff;
    margin: 0;
  }
  .brand__follow:hover { background: rgba(255,255,255,0.06); border-color: var(--accent); }
  .brand__follow svg { width: 18px; height: 18px; }
  .brand__proof { margin: 4px 0 24px; }
  .brand__avatars { display: flex; margin-bottom: 12px; }
  .brand__avatar { width: 52px; height: 52px; border-radius: 50%; object-fit: cover; border: 3px solid var(--bg); margin-left: -16px; background: var(--surface); }
  .brand__avatar:first-child { margin-left: 0; }
  .brand__stat { font-style: italic; font-size: 0.7rem; color: var(--muted-2); margin: 0; max-width: 44ch; }

  /* CONTACT */
  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: start;
  }
  .contact__email {
    display: inline-block;
    margin-top: 6px;
    color: var(--accent);
    font-family: var(--font-head);
    font-weight: 700;
  }
  .form { display: grid; gap: 16px; }
  .form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .field { display: grid; gap: 8px; }
  .field span { font-size: 0.92rem; color: var(--muted); }
  .field input,
  .field textarea {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 14px 16px;
    color: #fff;
    font: inherit;
    resize: vertical;
  }
  .field input:focus,
  .field textarea:focus { outline: 2px solid var(--accent); border-color: transparent; }
  .form .btn { justify-self: start; }

  /* FOOTER */
  .footer {
    background: var(--bg-elevated);
    border-radius: 32px 32px 0 0;
    margin-top: clamp(48px, 7vw, 96px);
    padding-top: clamp(44px, 5vw, 72px);
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1.2fr;
    gap: clamp(32px, 5vw, 72px);
    padding-bottom: clamp(40px, 5vw, 64px);
  }
  .footer__logo img { height: 58px; width: auto; display: block; }
  .footer__bio { color: var(--muted); margin: 22px 0 0; max-width: 34ch; font-size: 1rem; line-height: 1.6; }
  .footer__heading {
    text-transform: uppercase; letter-spacing: 0.14em;
    font-size: 0.76rem; font-weight: 700;
    color: var(--muted-2); margin: 0 0 20px;
  }
  .footer__links { display: flex; flex-direction: column; gap: 15px; }
  .footer__links a { color: #fff; width: fit-content; transition: color 0.2s ease; }
  .footer__links a:hover { color: var(--muted); }
  .footer__phrase {
    font-family: var(--font-head); font-weight: 700;
    font-size: 1.2rem; line-height: 1.3;
    margin: 0 0 30px; max-width: 28ch;
  }
  .footer__socials { display: flex; gap: 12px; }
  .footer__social {
    width: 46px; height: 46px;
    display: grid; place-items: center;
    border: 1px solid var(--line);
    border-radius: 12px;
    font-family: var(--font-head); font-weight: 700;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .footer__social:hover { background: rgba(255,255,255,0.06); border-color: var(--accent); }
  .footer__bottom { border-top: 1px solid var(--line); }
  .footer__legal {
    display: flex; align-items: center; justify-content: center; flex-wrap: wrap;
    gap: 10px; padding-block: 24px; margin: 0;
    color: var(--muted-2); font-size: 0.9rem;
  }
  .footer__legal a { color: var(--muted); transition: color 0.2s ease; }
  .footer__legal a:hover { color: #fff; }
  @media (max-width: 860px) {
    .footer__grid { grid-template-columns: 1fr; gap: 40px; }
  }

  /* RESPONSIVE */
  @media (max-width: 860px) {
    .hero__inner,
    .conf__inner,
    .brand__inner,
    .contact__inner { grid-template-columns: 1fr; }
    .brand__inner--reverse .brand__media { order: 0; }
    .tiles__grid { grid-template-columns: 1fr; }
    .hero__media { order: -1; }
  }
  @media (max-width: 520px) {
    .form__row { grid-template-columns: 1fr; }
    .conf__media { grid-template-columns: 1fr 1fr; }
  }
</style>
