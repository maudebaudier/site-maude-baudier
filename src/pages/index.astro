---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import site from "../data/site.json";

const { hero, trust, conferences, quote, parcours, tiles, brands, contact, footer } = site;
---

<Base>
  <a id="top"></a>
  <Header />

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="container hero__inner">
        <div class="hero__text reveal">
          <h1 class="hero__title">
            <span>{hero.titleLine1}</span>
            <span>{hero.titleLine2}</span>
          </h1>
          <p class="hero__subtitle">{hero.subtitle}</p>
          <a class="btn btn--light" href={hero.cta.href}>{hero.cta.label}</a>
        </div>
        <div class="hero__media reveal">
          <div class="hero__photo">
            <img src={hero.image} alt={hero.imageAlt} loading="eager" width="640" height="760" />
          </div>
        </div>
      </div>
    </section>

    <!-- TRUST -->
    <section class="trust section">
      <div class="container">
        <p class="trust__title reveal">{trust.title}</p>
        <div class="trust__logos reveal">
          {trust.logos.map((l) => <img src={l.image} alt={l.name} class="trust__logo" />)}
        </div>
      </div>
    </section>

    <!-- CONFERENCES -->
    <section class="section conf" id={conferences.id}>
      <div class="container conf__inner">
        <div class="conf__text reveal">
          <h2 class="h2">{conferences.title}</h2>
          <p class="lead">{conferences.text}</p>
          <a class="btn btn--ghost" href={conferences.cta.href}>{conferences.cta.label}</a>
        </div>
        <div class="conf__media reveal">
          {conferences.images.map((im) => (
            <div class="conf__card"><img src={im.image} alt={im.alt} /></div>
          ))}
        </div>
      </div>
    </section>

    <!-- QUOTE -->
    <section class="section quote">
      <div class="container">
        <blockquote class="quote__text reveal">
          <span class="quote__mark">“</span>{quote.text}<span class="quote__mark">”</span>
        </blockquote>
        <p class="quote__author reveal">
          <strong>{quote.author}</strong> · {quote.source}
        </p>
      </div>
    </section>

    <!-- PARCOURS -->
    <section class="section parcours" id={parcours.id}>
      <div class="container">
        <p class="eyebrow reveal">{parcours.eyebrow}</p>
        <h2 class="h2 reveal">{parcours.title}</h2>
        <div class="parcours__body reveal">
          {parcours.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <!-- TILES -->
    <section class="tiles">
      <div class="container tiles__grid">
        {tiles.map((t) => (
          <div class="tile reveal" style={`--c:${t.color}`} aria-label={t.alt}></div>
        ))}
      </div>
    </section>

    <!-- BRANDS -->
    {brands.map((b) => (
      <section class="section brand" id={b.id} style={`--accent:${b.accent}`}>
        <div class={`container brand__inner ${b.layout === "image-right" ? "brand__inner--reverse" : ""}`}>
          <div class="brand__media reveal">
            <div class="brand__photo"><img src={b.image} alt={b.imageAlt} /></div>
          </div>
          <div class="brand__text reveal">
            <h2 class="h2">{b.name}</h2>
            {b.paragraphs.map((p) => <p class="lead">{p}</p>)}
            <a class="btn" style="background:var(--accent);color:#fff" href={b.cta.href}>{b.cta.label}</a>
          </div>
        </div>
      </section>
    ))}

    <!-- CONTACT -->
    <section class="section contact" id={contact.id}>
      <div class="container contact__inner">
        <div class="contact__intro reveal">
          <h2 class="h2">{contact.title}</h2>
          <p class="lead">{contact.text}</p>
          <a class="contact__email" href={`mailto:${contact.email}`}>{contact.email}</a>
        </div>

        <form
          class="form reveal"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/merci"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="visually-hidden">
            <label>Ne pas remplir : <input name="bot-field" /></label>
          </p>
          <div class="form__row">
            <label class="field">
              <span>Nom</span>
              <input type="text" name="nom" required autocomplete="name" />
            </label>
            <label class="field">
              <span>Email</span>
              <input type="email" name="email" required autocomplete="email" />
            </label>
          </div>
          <label class="field">
            <span>Sujet</span>
            <input type="text" name="sujet" />
          </label>
          <label class="field">
            <span>Message</span>
            <textarea name="message" rows="5" required></textarea>
          </label>
          <button class="btn btn--light" type="submit">Envoyer le message</button>
        </form>
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <a class="footer__tagline" href={`mailto:${footer.email}`}>{footer.tagline}</a>
      <a class="footer__social" href={footer.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">in</a>
    </div>
  </footer>
</Base>

<style>
  .h2 { font-size: clamp(2rem, 5vw, 3.2rem); margin-bottom: 18px; }
  .lead { color: var(--muted); font-size: 1.08rem; max-width: 46ch; margin: 0 0 26px; }

  /* HERO */
  .hero { padding-top: clamp(36px, 6vw, 80px); padding-bottom: clamp(24px, 4vw, 48px); }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(24px, 5vw, 64px);
    align-items: center;
  }
  .hero__title {
    font-size: clamp(3rem, 9vw, 6.4rem);
    font-weight: 900;
    display: flex;
    flex-direction: column;
  }
  .hero__subtitle {
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    color: var(--muted);
    margin: 24px 0 32px;
    max-width: 28ch;
  }
  .hero__photo {
    background: linear-gradient(160deg, var(--navy-2), var(--navy));
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 5 / 6;
  }
  .hero__photo img { width: 100%; height: 100%; object-fit: cover; }

  /* TRUST */
  .trust { padding-block: clamp(32px, 5vw, 64px); }
  .trust__title { text-align: center; color: var(--muted-2); margin: 0 0 28px; font-weight: 600; }
  .trust__logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: clamp(28px, 6vw, 72px);
    opacity: 0.85;
  }
  .trust__logo { height: 30px; width: auto; filter: brightness(0) invert(1); opacity: 0.75; }

  /* CONFERENCES */
  .conf__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 5vw, 64px);
    align-items: center;
  }
  .conf__media { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .conf__card {
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: linear-gradient(160deg, var(--navy-2), #060615);
  }
  .conf__card img { width: 100%; height: 100%; object-fit: cover; }

  /* QUOTE */
  .quote { text-align: left; }
  .quote__text {
    font-family: var(--font-head);
    font-weight: 800;
    font-style: italic;
    font-size: clamp(1.6rem, 4.4vw, 3rem);
    line-height: 1.15;
    margin: 0 0 20px;
    max-width: 20ch;
  }
  .quote__mark { color: var(--accent); }
  .quote__author { color: var(--muted-2); margin: 0; }
  .quote__author strong { color: var(--text); }

  /* PARCOURS */
  .parcours__body { columns: 2; column-gap: clamp(32px, 5vw, 64px); margin-top: 12px; }
  .parcours__body p { margin: 0 0 18px; color: var(--muted); break-inside: avoid; }

  /* TILES */
  .tiles { padding-block: clamp(8px, 2vw, 24px); }
  .tiles__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(14px, 2vw, 22px); }
  .tile {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    background-color: var(--c);
    background-image: var(--grain);
    background-size: 180px 180px;
    background-blend-mode: multiply;
  }

  /* BRANDS */
  .brand__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 5vw, 64px);
    align-items: center;
  }
  .brand__inner--reverse .brand__media { order: 2; }
  .brand__photo {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: linear-gradient(160deg, var(--navy-2), #060615);
  }
  .brand__photo img { width: 100%; height: 100%; object-fit: cover; }

  /* CONTACT */
  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: start;
  }
  .contact__email {
    display: inline-block;
    margin-top: 6px;
    color: var(--accent);
    font-family: var(--font-head);
    font-weight: 700;
  }
  .form { display: grid; gap: 16px; }
  .form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .field { display: grid; gap: 8px; }
  .field span { font-size: 0.92rem; color: var(--muted); }
  .field input,
  .field textarea {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 14px 16px;
    color: #fff;
    font: inherit;
    resize: vertical;
  }
  .field input:focus,
  .field textarea:focus { outline: 2px solid var(--accent); border-color: transparent; }
  .form .btn { justify-self: start; }

  /* FOOTER */
  .footer { border-top: 1px solid var(--line); padding-block: 28px; }
  .footer__inner { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
  .footer__tagline { font-family: var(--font-head); font-weight: 700; font-size: 1.1rem; }
  .footer__social {
    width: 40px; height: 40px;
    display: grid; place-items: center;
    border: 1px solid var(--line);
    border-radius: 10px;
    font-family: var(--font-head); font-weight: 700;
  }
  .footer__social:hover { background: rgba(255,255,255,0.06); }

  /* RESPONSIVE */
  @media (max-width: 860px) {
    .hero__inner,
    .conf__inner,
    .brand__inner,
    .contact__inner { grid-template-columns: 1fr; }
    .brand__inner--reverse .brand__media { order: 0; }
    .parcours__body { columns: 1; }
    .tiles__grid { grid-template-columns: 1fr; }
    .hero__media { order: -1; }
  }
  @media (max-width: 520px) {
    .form__row { grid-template-columns: 1fr; }
    .conf__media { grid-template-columns: 1fr 1fr; }
  }
</style>
