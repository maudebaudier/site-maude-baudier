---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
---

<Base title="Merci — Maude Baudier">
  <a id="top"></a>
  <Header />
  <main>
    <section class="section">
      <div class="container" style="text-align:center; max-width:640px; padding-block: clamp(48px,10vw,120px);">
        <h1 style="font-size:clamp(2.4rem,7vw,4rem); margin-bottom:18px;">Merci !</h1>
        <p style="color:var(--muted); font-size:1.15rem; margin-bottom:32px;">
          Votre message a bien été envoyé. Je vous réponds dans les plus brefs délais.
        </p>
        <a class="btn btn--light" href="/">Retour à l'accueil</a>
      </div>
    </section>
  </main>
</Base>
