---
import site from "../data/site.json";
const { nav, brand } = site;
---

<header class="header">
  <div class="container header__inner">
    <a class="logo" href="#top" aria-label={brand.name}>
      <span>Maude</span>
      <span>Baudier</span>
    </a>

    <nav class="nav" data-menu aria-label="Navigation principale">
      {
        nav.map((item) =>
          item.highlight ? (
            <a class={`nav__link nav__link--btn ${item.accent === "warm" ? "nav__link--warm" : ""}`} href={item.href}>{item.label}</a>
          ) : (
            <a class="nav__link" href={item.href}>{item.label}</a>
          )
        )
      }
    </nav>

    <button class="burger" data-burger aria-label="Ouvrir le menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(10px);
    background: rgba(10, 10, 15, 0.7);
    border-bottom: 1px solid var(--line);
  }
  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-block: 14px;
  }
  .logo {
    display: inline-flex;
    flex-direction: column;
    line-height: 0.92;
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    background: var(--navy);
    color: #fff;
    padding: 12px 16px;
    border-radius: 14px;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .nav__link {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1rem;
    padding: 10px 6px;
    color: #fff;
    transition: opacity 0.2s ease;
  }
  .nav__link:hover { opacity: 0.7; }
  .nav__link--btn {
    background: var(--accent);
    padding: 12px 22px;
    border-radius: 999px;
  }
  .nav__link--btn:hover { opacity: 1; background: #bb1656; }
  .nav__link--warm { background: var(--accent-warm); color: #1a1208; }
  .nav__link--warm:hover { background: #f4894e; }

  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 12px;
    cursor: pointer;
  }
  .burger span {
    display: block;
    height: 2px;
    width: 20px;
    margin-inline: auto;
    background: #fff;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (max-width: 860px) {
    .burger { display: flex; }
    .nav {
      position: fixed;
      inset: 0;
      flex-direction: column;
      justify-content: center;
      gap: 28px;
      background: rgba(10, 10, 15, 0.98);
      transform: translateX(100%);
      transition: transform 0.3s ease;
    }
    .nav.is-open { transform: none; }
    .nav__link { font-size: 1.6rem; }
  }
</style>
