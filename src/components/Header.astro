---
import site from "../data/site.json";
const { nav, brand } = site;
---

<header class="header">
  <div class="container header__inner">
    <a class={`logo ${brand.logo ? "logo--img" : ""}`} href="/" aria-label={brand.name}>
      {brand.logo ? (
        <img class="logo__img" src={brand.logo} alt={brand.name} />
      ) : (
        <><span>Maude</span><span>Baudier</span></>
      )}
    </a>

    <nav class="nav" data-menu aria-label="Navigation principale">
      {
        nav.map((item) =>
          item.highlight ? (
            <a class={`nav__link nav__link--btn ${item.accent === "warm" ? "nav__link--warm" : ""}`} href={item.href}>{item.label}</a>
          ) : (
            <a class="nav__link" href={item.href}>{item.label}</a>
          )
        )
      }
    </nav>

    <button class="burger" data-burger aria-label="Ouvrir le menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(10px);
    background: rgba(8, 15, 44, 0.72);
    border-bottom: 1px solid var(--line);
  }
  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-block: 14px;
  }
  .logo {
    display: inline-flex;
    flex-direction: column;
    line-height: 0.92;
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    background: var(--navy);
    color: #fff;
    padding: 12px 16px;
    border-radius: 14px;
  }
  .logo--img { background: transparent; padding: 0; border-radius: 0; }
  .logo__img { height: 52px; width: auto; display: block; }
  .nav {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .nav__link {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1rem;
    padding: 10px 6px;
    color: #fff;
    transition: opacity 0.2s ease;
  }
  .nav__link:hover { opacity: 0.7; }
  .nav__link--btn {
    background: var(--accent);
    padding: 12px 22px;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 255, 255, 0.22);
  }
  .nav__link--btn:hover { opacity: 1; background: #bb1656; }
  .nav__link--warm { background: var(--accent-warm); color: #1a1208; }
  .nav__link--warm:hover { background: #f4894e; }

  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 12px;
    cursor: pointer;
  }
  .burger span {
    display: block;
    height: 2px;
    width: 20px;
    margin-inline: auto;
    background: #fff;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  /* État X de l'icône burger quand le menu est ouvert */
  .burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 860px) {
    /* IMPORTANT : retirer le backdrop-filter sur mobile.
       Un parent avec backdrop-filter casse le position:fixed de l'overlay,
       qui se retrouve confiné au header au lieu de couvrir tout l'écran. */
    .header {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
    .burger {
      display: flex;
      position: relative;
      z-index: 110;
    }
    .nav {
      position: fixed;
      inset: 0;
      z-index: 100;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 22px;
      padding: 24px;
      background: var(--bg);
      transform: translateX(100%);
      transition: transform 0.3s ease;
      overflow-y: auto;
    }
    .nav.is-open { transform: none; }
    .nav__link { font-size: 1.4rem; }
  }
</style>
